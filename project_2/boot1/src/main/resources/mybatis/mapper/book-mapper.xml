<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.the703.dao.BookDao">

    <!-- ========================================================= -->
    <!-- 📘 전체 조회 (Oracle OFFSET/FETCH 페이징) -->
    <!-- ========================================================= -->
    <select id="findAll" resultType="BookDto" parameterType="java.util.HashMap">
        SELECT *
        FROM BOOK
        ORDER BY BOOK_ID DESC
        OFFSET #{start} ROWS FETCH NEXT #{end} ROWS ONLY
    </select>

    <select id="findAllCnt" resultType="int">
        SELECT COUNT(*) FROM BOOK
    </select>


    <!-- ========================================================= -->
    <!-- 📘 단건 조회 -->
    <!-- ========================================================= -->
    <select id="findById" resultType="BookDto" parameterType="BookDto">
        SELECT *
        FROM BOOK
        WHERE BOOK_ID = #{bookId}
    </select>


    <!-- ========================================================= -->
    <!-- 📘 등록 (Oracle: 날짜 변환 필요) -->
    <!-- ========================================================= -->
    <insert id="insert" parameterType="BookDto">
        INSERT INTO BOOK (
            BOOK_ID, TITLE, AUTHOR, PUBLISHER, PUBLISH_DATE, CATEGORY,
            RANKING, REVIEW_COUNT, RATING, DESCRIPTION, PAGES,
            PRICE, BOOK_COVER
        ) VALUES (
            SEQ_BOOK_ID.NEXTVAL,
            #{title},
            #{author},
            #{publisher},
            TO_DATE(#{publishDate}, 'YYYY-MM-DD'),
            #{category},
            #{ranking},
            #{reviewCount},
            #{rating},
            #{description},
            #{pages},
            #{price},
            #{bookCover}
        )
    </insert>


    <!-- ========================================================= -->
    <!-- 📘 수정 -->
    <!-- ========================================================= -->
	<update id="update" parameterType="BookDto">
	    UPDATE BOOK
	    <set>
	        <if test="title != null">TITLE = #{title},</if>
	        <if test="author != null">AUTHOR = #{author},</if>
	        <if test="publisher != null">PUBLISHER = #{publisher},</if>
	        <if test="publishDate != null">PUBLISH_DATE = TO_DATE(#{publishDate}, 'YYYY-MM-DD'),</if>
	        <if test="category != null">CATEGORY = #{category},</if>
	        <if test="ranking != null">RANKING = #{ranking},</if>
	        <if test="reviewCount != null">REVIEW_COUNT = #{reviewCount},</if>
	        <if test="rating != null">RATING = #{rating},</if>
	        <if test="description != null">DESCRIPTION = #{description},</if>
	        <if test="pages != null">PAGES = #{pages},</if>
	        <if test="price != null">PRICE = #{price},</if>
	        <if test="bookCover != null">BOOK_COVER = #{bookCover}</if>
	    </set>
	    WHERE BOOK_ID = #{bookId}
	</update>


    <!-- ========================================================= -->
    <!-- 📘 삭제 -->
    <!-- ========================================================= -->
    <delete id="delete" parameterType="BookDto">
        DELETE FROM BOOK
        WHERE BOOK_ID = #{bookId}
    </delete>


    <!-- ========================================================= -->
    <!-- 📘 카테고리별 조회 -->
    <!-- ========================================================= -->
