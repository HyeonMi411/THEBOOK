    <!-- ========================================================= -->
    <!-- 🔍 통합 검색 (제목 + 저자 + 카테고리) -->
    <!-- ========================================================= -->
<!--     <select id="searchBooks" resultType="BookDto" parameterType="BookDto">
        SELECT *
        FROM BOOK
        WHERE
            (
                (#{searchType} = 'title' AND TITLE LIKE '%' || #{keyword} || '%')
                OR (#{searchType} = 'author' AND AUTHOR LIKE '%' || #{keyword} || '%')
                OR (#{searchType} = 'category' AND CATEGORY LIKE '%' || #{keyword} || '%')
            )
        ORDER BY
            CASE
                WHEN #{orderBy} = 'rating' THEN RATING
                WHEN #{orderBy} = 'reviewCount' THEN REVIEW_COUNT
                ELSE BOOK_ID
            END DESC
