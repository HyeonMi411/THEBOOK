	<!-- 🔍 통합 검색 (정렬을 BOOK_ID 최신순으로 단일화) -->
	<select id="searchBooks" resultType="BookDto" parameterType="BookDto">
	    SELECT *
	    FROM BOOK
	    <where>
	        <choose>
	            <when test="searchType == 'title'">
	                TITLE LIKE '%' || #{keyword} || '%'
	            </when>
	            <when test="searchType == 'author'">
	                AUTHOR LIKE '%' || #{keyword} || '%'
	            </when>
	            <when test="searchType == 'category'">
	                CATEGORY LIKE '%' || #{keyword} || '%'
	            </when>
	        </choose>
	    </where>
	    ORDER BY BOOK_ID DESC
	</select>


